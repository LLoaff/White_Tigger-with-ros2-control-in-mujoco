<contact>
  <!-- base与所有hip连杆的碰撞 -->
  <exclude body1="root" body2="fr_hip_Link" />
  <exclude body1="root" body2="fl_hip_Link" />
  <exclude body1="root" body2="br_hip_Link" />
  <exclude body1="root" body2="bl_hip_Link" />
  
  <!-- base与所有thigh连杆的碰撞（这是你之前漏掉的关键！） -->
  <exclude body1="root" body2="fr_thigh_Link" />
  <exclude body1="root" body2="fl_thigh_Link" />
  <exclude body1="root" body2="br_thigh_Link" />
  <exclude body1="root" body2="bl_thigh_Link" />
  
  <!-- hip与thigh连杆的碰撞 -->
  <exclude body1="fr_hip_Link" body2="fr_thigh_Link" />
  <exclude body1="fl_hip_Link" body2="fl_thigh_Link" />
  <exclude body1="br_hip_Link" body2="br_thigh_Link" />
  <exclude body1="bl_hip_Link" body2="bl_thigh_Link" />
  
  <!-- thigh与calf连杆的碰撞 -->
  <exclude body1="fr_thigh_Link" body2="fr_calf_Link" />
  <exclude body1="fl_thigh_Link" body2="fl_calf_Link" />
  <exclude body1="br_thigh_Link" body2="br_calf_Link" />
  <exclude body1="bl_thigh_Link" body2="bl_calf_Link" />
  
  <!-- hip与calf连杆的碰撞（防止大角度转动时碰撞） -->
  <exclude body1="fr_hip_Link" body2="fr_calf_Link" />
  <exclude body1="fl_hip_Link" body2="fl_calf_Link" />
  <exclude body1="br_hip_Link" body2="br_calf_Link" />
  <exclude body1="bl_hip_Link" body2="bl_calf_Link" />
</contact>

